LLM_MODEL=llama3.2:1b
OLLAMA_BASE_URL=http://localhost:11434

EMBEDDING_MODEL=all-MiniLM-L6-v2

VECTOR_DB_PROVIDER=chroma

CHROMA_PERSIST_DIR=./data/vectorstore
CHROMA_COLLECTION_NAME=rag_documents

PINECONE_API_KEY=replace-with-your-pinecone-api-key
PINECONE_INDEX_NAME=rag-system-index

MONGODB_ATLAS_URI=replace-with-your-mongodb-atlas-connection-string
MONGODB_DB_NAME=rag_system
MONGODB_COLLECTION_NAME=document_chunks
MONGODB_VECTOR_INDEX_NAME=vector_index

CHUNKING_STRATEGY=recursive
CHUNK_SIZE=500
CHUNK_OVERLAP=50

TOP_K=4